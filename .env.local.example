# Required — core
DATABASE_URL=postgresql://user:password@host:5432/business_console
REDIS_URL=redis://localhost:6379
SESSION_SECRET=change-me-to-a-random-32-plus-character-string

# Required — auth
CONSOLE_PASSWORD=your-admin-password

# Required — Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+852xxxxxxxx

# Required — service URLs
WEBHOOK_BASE_URL=https://your-business-console.zeabur.app
VOICE_WEBHOOK_URL=https://your-voice-claw-webhook.zeabur.app

# Required — AI (post-call summarisation + KB embedding)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional — campaign defaults
CAMPAIGN_CONCURRENCY=3

# Optional — Phase 2 (inbound hotline, add later)
# QDRANT_URL=https://your-qdrant-instance
# QDRANT_API_KEY=your-qdrant-key
